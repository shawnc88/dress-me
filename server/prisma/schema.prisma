generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String
  displayName   String
  avatarUrl     String?
  bio           String?
  role          UserRole @default(VIEWER)
  isVerified    Boolean  @default(false)
  threadBalance Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  subscription    Subscription?
  creatorProfile  CreatorProfile?
  sentGifts       Gift[]           @relation("GiftSender")
  chatMessages    ChatMessage[]
  giveawayEntries GiveawayEntry[]
  notifications   Notification[]
  raffleEntries   RaffleEntry[]
  raffleWins      RaffleWinner[]
  posts           Post[]
  postLikes       PostLike[]
  postComments    PostComment[]
  sentMessages     DirectMessage[] @relation("MessageSender")
  conversations1   Conversation[]  @relation("ConvUser1")
  conversations2   Conversation[]  @relation("ConvUser2")
  fanSubscriptions FanSubscription[]

  @@index([email])
  @@index([username])
}

enum UserRole {
  VIEWER
  CREATOR
  MODERATOR
  ADMIN
}

// ─── Creator Profiles ────────────────────────────────────────────

model CreatorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        String   @default("fashion")
  totalEarnings   Int      @default(0) // in cents
  threadBalance   Int      @default(0)
  isLive          Boolean  @default(false)
  streamKey       String   @unique @default(cuid())
  socialLinks     Json?
  isOnboarded     Boolean  @default(false)
  tierBasicPrice  Int      @default(0)    // cents/month — 0 = free
  tierPremiumPrice Int     @default(999)  // cents/month
  tierElitePrice  Int      @default(2999) // cents/month, 0 = disabled
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  streams    Stream[]
  giveaways  Giveaway[]
  raffles    Raffle[]

  @@index([userId])
}

// ─── Subscriptions ───────────────────────────────────────────────

model Subscription {
  id                String           @id @default(cuid())
  userId            String           @unique
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier              SubscriptionTier
  status            SubStatus        @default(ACTIVE)
  stripeCustomerId  String?
  stripeSubId       String?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
}

enum SubscriptionTier {
  BASIC
  PREMIUM
  ELITE
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

// ─── Streams ─────────────────────────────────────────────────────

model Stream {
  id            String       @id @default(cuid())
  creatorId     String
  creator       CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  thumbnailUrl  String?
  status        StreamStatus @default(SCHEDULED)
  streamType    StreamType   @default(PUBLIC)
  startedAt     DateTime?
  endedAt       DateTime?
  viewerCount   Int          @default(0)
  peakViewers   Int          @default(0)
  replayUrl     String?
  scheduledFor  DateTime?
  muxStreamId      String?
  muxPlaybackId    String?
  muxStreamKey     String?      // stored for browser mode egress
  ingestMode       String       @default("rtmp") // "rtmp" | "browser"
  livekitRoomName  String?
  livekitEgressId  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  chatMessages ChatMessage[]
  polls        Poll[]
  gifts        Gift[]
  raffles      Raffle[]

  @@index([creatorId])
  @@index([status])
  @@index([scheduledFor])
}

enum StreamStatus {
  SCHEDULED
  LIVE
  ENDED
  ARCHIVED
}

enum StreamType {
  PUBLIC
  PREMIUM
  ELITE
  PRIVATE
}

// ─── Chat ────────────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  streamId  String
  stream    Stream   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  type      MessageType @default(TEXT)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([streamId, createdAt])
}

enum MessageType {
  TEXT
  GIFT
  SYSTEM
  POLL
}

// ─── Gifts & Threads ─────────────────────────────────────────────

model Gift {
  id        String   @id @default(cuid())
  streamId  String
  stream    Stream   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("GiftSender", fields: [senderId], references: [id])
  giftType  String
  threads   Int      // cost in Threads
  message   String?
  createdAt DateTime @default(now())

  @@index([streamId])
  @@index([senderId])
}

model ThreadPurchase {
  id              String   @id @default(cuid())
  userId          String
  threads         Int
  amountCents     Int
  stripePaymentId String?
  status          String   @default("completed")
  createdAt       DateTime @default(now())

  @@index([userId])
}

// ─── Polls ───────────────────────────────────────────────────────

model Poll {
  id        String       @id @default(cuid())
  streamId  String
  stream    Stream       @relation(fields: [streamId], references: [id], onDelete: Cascade)
  question  String
  options   Json         // [{id, text, votes}]
  isActive  Boolean      @default(true)
  endsAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([streamId])
}

// ─── Giveaways ───────────────────────────────────────────────────

model Giveaway {
  id             String          @id @default(cuid())
  creatorId      String
  creator        CreatorProfile  @relation(fields: [creatorId], references: [id])
  title          String
  description    String
  prizeDetails   String
  prizeValueUsd  Int             // in cents
  rulesUrl       String          // link to official rules
  amoeMethod     String          // free alternative method of entry description
  eligibility    String          // eligibility requirements
  status         GiveawayStatus  @default(DRAFT)
  startDate      DateTime
  endDate        DateTime
  winnerId       String?
  maxEntries     Int?
  requiresStateReg Boolean       @default(false) // NY/FL registration needed
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  entries GiveawayEntry[]

  @@index([creatorId])
  @@index([status])
}

enum GiveawayStatus {
  DRAFT
  ACTIVE
  CLOSED
  WINNER_SELECTED
  COMPLETED
}

model GiveawayEntry {
  id          String   @id @default(cuid())
  giveawayId  String
  giveaway    Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  entryMethod String   // "purchase" or "amoe"
  createdAt   DateTime @default(now())

  @@unique([giveawayId, userId])
  @@index([giveawayId])
}

// ─── Viewer Sessions (real-time presence) ────────────────────────

model ViewerSession {
  id         String    @id @default(cuid())
  streamId   String
  userId     String?
  guestToken String?
  isActive   Boolean   @default(true)
  joinedAt   DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  leftAt     DateTime?

  @@index([streamId, isActive])
  @@index([userId])
  @@index([lastSeenAt])
}

// ─── Stream Revenue ─────────────────────────────────────────────

model StreamRevenue {
  id               String   @id @default(cuid())
  streamId         String
  creatorId        String
  sourceType       String   // gift, tip, tier_subscription
  sourceId         String
  grossAmountCents Int
  platformFeeCents Int
  creatorNetCents  Int
  createdAt        DateTime @default(now())

  @@index([streamId])
  @@index([creatorId])
  @@index([createdAt])
}

// ─── Notifications ───────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

// ─── Push Subscriptions ─────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Posts (Instagram-style) ─────────────────────────────────

model Post {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  likes    PostLike[]
  comments PostComment[]

  @@index([userId])
  @@index([createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

// ─── Raffles ─────────────────────────────────────────────────────

model Raffle {
  id             String       @id @default(cuid())
  creatorId      String
  creator        CreatorProfile @relation(fields: [creatorId], references: [id])
  streamId       String?
  stream         Stream?      @relation(fields: [streamId], references: [id])
  title          String
  status         RaffleStatus @default(OPEN)
  closesAt       DateTime
  maxWinners     Int
  tierWeights    Json         @default("{}")  // e.g. {"BASIC":1,"PREMIUM":3,"ELITE":10}
  drawSeed       String?      // hex-encoded random seed for auditability
  drawnAt        DateTime?
  createdAt      DateTime     @default(now())

  entries  RaffleEntry[]
  winners  RaffleWinner[]

  @@index([creatorId])
  @@index([streamId])
}

enum RaffleStatus {
  OPEN
  DRAWN
  CANCELLED
}

model RaffleEntry {
  id              String   @id @default(cuid())
  raffleId        String
  raffle          Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  subscriberUserId String
  subscriber      User     @relation(fields: [subscriberUserId], references: [id])
  tier            String
  tickets         Int
  createdAt       DateTime @default(now())

  @@unique([raffleId, subscriberUserId])
  @@index([raffleId])
}

model RaffleWinner {
  id              String   @id @default(cuid())
  raffleId        String
  raffle          Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  subscriberUserId String
  subscriber      User     @relation(fields: [subscriberUserId], references: [id])
  tier            String
  rank            Int
  selectedAt      DateTime @default(now())

  @@unique([raffleId, subscriberUserId])
  @@unique([raffleId, rank])
  @@index([raffleId])
}

// ─── Stories (Instagram-style, 24h expiry) ──────────────────────

model Story {
  id         String    @id @default(cuid())
  creatorId  String
  mediaUrl   String
  mediaType  String    @default("image") // "image" | "video"
  caption    String?
  expiresAt  DateTime
  viewCount  Int       @default(0)
  createdAt  DateTime  @default(now())

  viewers StoryView[]

  @@index([creatorId])
  @@index([expiresAt])
  @@index([createdAt])
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    String
  viewedAt  DateTime @default(now())

  @@unique([storyId, userId])
  @@index([storyId])
  @@index([userId])
}

// ─── Reels (TikTok-style short video) ───────────────────────────

model Reel {
  id             String   @id @default(cuid())
  creatorId      String
  videoUrl       String
  muxAssetId     String?
  muxPlaybackId  String?
  thumbnailUrl   String?
  caption        String?
  hashtags       String[] // stored as array of tag strings
  duration       Int?     // seconds
  likesCount     Int      @default(0)
  commentsCount  Int      @default(0)
  sharesCount    Int      @default(0)
  viewsCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  likes    ReelLike[]
  comments ReelComment[]

  @@index([creatorId])
  @@index([createdAt])
  @@index([likesCount])
  @@index([viewsCount])
}

model ReelLike {
  id        String   @id @default(cuid())
  reelId    String
  reel      Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([reelId, userId])
  @@index([reelId])
}

model ReelComment {
  id        String   @id @default(cuid())
  reelId    String
  reel      Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  createdAt DateTime @default(now())

  @@index([reelId, createdAt])
}

// ─── Reel Engagement (for algorithm) ────────────────────────────

model ReelEngagement {
  id          String   @id @default(cuid())
  reelId      String
  userId      String
  watchTimeMs Int      @default(0)
  completed   Boolean  @default(false)
  liked       Boolean  @default(false)
  commented   Boolean  @default(false)
  shared      Boolean  @default(false)
  followed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([reelId, userId])
  @@index([reelId])
  @@index([userId])
  @@index([createdAt])
}

// ─── Mux Webhook Events (idempotency) ──────────────────────────

model MuxWebhookEvent {
  eventId    String   @id
  eventType  String
  receivedAt DateTime @default(now())
  payload    Json

  @@index([eventType])
}

// ─── Feed Algorithm ─────────────────────────────────────────────

model FeedEvent {
  id        String   @id @default(cuid())
  userId    String
  creatorId String
  streamId  String?
  event     String   // impression, view_start, view_3s, view_30s, like, comment, follow, profile_open, stream_join, tier_click, tier_subscribe, skip, return_view
  meta      Json?    // extra data (e.g. watch duration, category)
  createdAt DateTime @default(now())

  @@index([userId, creatorId])
  @@index([userId, event])
  @@index([creatorId, event])
  @@index([createdAt])
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  targetUserId String?
  targetStreamId String?
  reason      String   // harassment, explicit, illegal, spam, other
  details     String?
  status      String   @default("pending") // pending, reviewed, resolved, dismissed
  createdAt   DateTime @default(now())

  @@index([reporterId])
  @@index([targetUserId])
  @@index([status])
}

model UserBlock {
  id          String   @id @default(cuid())
  blockerId   String
  blockedId   String
  createdAt   DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String   // who shared the link
  referredId  String?  // who signed up (null until they join)
  code        String   @unique // short referral code
  streamId    String?  // optional: stream-specific referral
  rewardGiven Boolean  @default(false)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([referrerId])
  @@index([code])
}

model UserFollow {
  id         String   @id @default(cuid())
  followerId String   // who is following
  creatorId  String   // who is being followed
  createdAt  DateTime @default(now())

  @@unique([followerId, creatorId])
  @@index([followerId])
  @@index([creatorId])
}

// ─── Growth System ──────────────────────────────────────────────

model UserStreak {
  id              String   @id @default(cuid())
  userId          String   @unique
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastActiveDate  String   // YYYY-MM-DD format for easy comparison
  totalCoinsEarned Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badge     String   // first_stream, streak_7, streak_30, top_fan, vip, elite, inner_circle, early_supporter, gift_king
  earnedAt  DateTime @default(now())

  @@unique([userId, badge])
  @@index([userId])
}

model CreatorBoost {
  id         String   @id @default(cuid())
  creatorId  String
  boostType  String   // new_creator, momentum, trending, rising
  boostScore Int      @default(0)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([creatorId])
  @@index([expiresAt])
}

// ─── SYSTEM 1: AI Feed Personalization ──────────────────────────

model UserPreferenceProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  fashionScore         Float    @default(0)
  stylingScore         Float    @default(0)
  liveScore            Float    @default(0)
  reelsScore           Float    @default(0)
  storyScore           Float    @default(0)
  premiumAffinityScore Float    @default(0)
  creatorAffinity      Json     @default("{}") // Record<creatorId, score>
  hashtagAffinity      Json     @default("{}") // Record<tag, score>
  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())

  @@index([userId])
}

model ContentRankingSignal {
  id              String   @id @default(cuid())
  userId          String
  contentId       String   // stream/reel/story ID
  contentType     String   // "stream" | "reel" | "story"
  creatorId       String
  watchTimeMs     Int      @default(0)
  completed       Boolean  @default(false)
  liked           Boolean  @default(false)
  commented       Boolean  @default(false)
  shared          Boolean  @default(false)
  followed        Boolean  @default(false)
  skipped         Boolean  @default(false)
  profileOpened   Boolean  @default(false)
  tierClicked     Boolean  @default(false)
  subscribed      Boolean  @default(false)
  replayCount     Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([userId, contentId])
  @@index([userId])
  @@index([contentId])
  @@index([creatorId])
  @@index([createdAt])
}

// ─── SYSTEM 2: Push Notification Engine ─────────────────────────

model PushDevice {
  id         String   @id @default(cuid())
  userId     String
  platform   String   // "web" | "ios" | "android"
  pushToken  String   @unique
  deviceName String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model NotificationPreference {
  id              String  @id @default(cuid())
  userId          String  @unique
  creatorLive     Boolean @default(true)
  creatorReel     Boolean @default(true)
  creatorStory    Boolean @default(true)
  likes           Boolean @default(true)
  comments        Boolean @default(true)
  follows         Boolean @default(true)
  gifts           Boolean @default(true)
  mentions        Boolean @default(true)
  streakReminder  Boolean @default(true)
  comebackAlert   Boolean @default(true)
  quietHoursStart Int?    // hour 0-23, null = disabled
  quietHoursEnd   Int?    // hour 0-23

  @@index([userId])
}

model NotificationDelivery {
  id               String    @id @default(cuid())
  userId           String
  notificationType String    // creator_live, creator_reel, streak_reminder, etc.
  title            String
  body             String
  data             Json?
  sentAt           DateTime  @default(now())
  openedAt         DateTime?
  delivered        Boolean   @default(true)

  @@index([userId])
  @@index([notificationType])
  @@index([sentAt])
}

// ─── SYSTEM 3: Creator Growth Metrics ───────────────────────────

model CreatorGrowthMetric {
  id                    String   @id @default(cuid())
  creatorId             String
  date                  String   // YYYY-MM-DD
  newFollowers          Int      @default(0)
  unfollows             Int      @default(0)
  streamCount           Int      @default(0)
  totalViewers          Int      @default(0)
  avgWatchTimeMs        Int      @default(0)
  followConversionRate  Float    @default(0) // follows / unique viewers
  repeatViewerRate      Float    @default(0) // returning viewers / total
  reelViews             Int      @default(0)
  reelLikes             Int      @default(0)
  storyViews            Int      @default(0)
  createdAt             DateTime @default(now())

  @@unique([creatorId, date])
  @@index([creatorId])
  @@index([date])
}

model PostStreamSummary {
  id                String   @id @default(cuid())
  streamId          String   @unique
  creatorId         String
  duration          Int      @default(0) // seconds
  peakViewers       Int      @default(0)
  totalViewers      Int      @default(0)
  newFollowers      Int      @default(0)
  giftsReceived     Int      @default(0)
  giftValueThreads  Int      @default(0)
  chatMessages      Int      @default(0)
  avgWatchTimeMs    Int      @default(0)
  repeatViewerRate  Float    @default(0)
  topFanUserIds     String[] // up to 5
  createdAt         DateTime @default(now())

  @@index([creatorId])
  @@index([createdAt])
}

// ─── Creator Tiers (per-creator subscription tiers) ─────────────

model CreatorTier {
  id                String   @id @default(cuid())
  creatorId         String
  name              CreatorTierName
  priceCents        Int
  yearlyPriceCents  Int?     // null = no annual option. E.g. 4990 for $49.90/yr
  billingInterval   String   @default("month")
  description       String   @default("")
  benefits          String[] // array of benefit descriptions
  active            Boolean  @default(true)
  slotLimit         Int?     // null = unlimited (used for Inner Circle)
  stripePriceId     String?  // Stripe monthly Price ID
  stripeYearlyPriceId String? // Stripe yearly Price ID
  appleProductId    String?  // Apple IAP monthly product ID
  appleYearlyProductId String? // Apple IAP yearly product ID
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  fanSubscriptions FanSubscription[]

  @@unique([creatorId, name])
  @@index([creatorId])
}

enum CreatorTierName {
  SUPPORTER
  VIP
  INNER_CIRCLE
}

// ─── Fan Subscriptions (per-creator) ────────────────────────────

model FanSubscription {
  id                     String              @id @default(cuid())
  userId                 String
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  creatorId              String
  tierId                 String
  tier                   CreatorTier         @relation(fields: [tierId], references: [id])
  status                 FanSubStatus        @default(ACTIVE)
  provider               BillingProvider
  providerSubscriptionId String?
  startedAt              DateTime            @default(now())
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean             @default(false)
  endsAt                 DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@unique([userId, creatorId])
  @@index([userId])
  @@index([creatorId])
  @@index([tierId])
  @@index([status])
  @@index([creatorId, status])
  @@index([currentPeriodEnd])
}

enum FanSubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum BillingProvider {
  STRIPE
  APPLE_IAP
}

// ─── Suite Sessions (multi-person live) ─────────────────────────

model SuiteSession {
  id              String       @id @default(cuid())
  streamId        String       @unique
  creatorId       String
  livekitRoom     String       @unique
  status          SuiteStatus  @default(WAITING)
  maxGuests       Int          @default(3)
  isPublic        Boolean      @default(false) // audience can watch
  livekitEgressId String?      // if broadcasting publicly via Mux
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  candidates SuiteCandidate[]
  selections SuiteSelection[]
  invites    SuiteInvite[]

  @@index([streamId])
  @@index([creatorId])
  @@index([status])
}

enum SuiteStatus {
  WAITING    // suite created, no guests yet
  ACTIVE     // creator + guests live
  ENDED
}

// ─── Suite Candidates (eligible fans) ───────────────────────────

model SuiteCandidate {
  id           String   @id @default(cuid())
  suiteId      String
  suite        SuiteSession @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  userId       String
  tierId       String
  tierName     CreatorTierName
  eligible     Boolean  @default(true)
  weightScore  Float    @default(0)
  reason       String?  // why eligible/ineligible
  createdAt    DateTime @default(now())

  @@unique([suiteId, userId])
  @@index([suiteId])
  @@index([userId])
}

// ─── Suite Selections (who was picked) ──────────────────────────

model SuiteSelection {
  id              String   @id @default(cuid())
  suiteId         String
  suite           SuiteSession @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  selectedUserIds String[]
  mode            SelectionMode
  createdAt       DateTime @default(now())

  @@index([suiteId])
}

enum SelectionMode {
  MANUAL
  WEIGHTED
  RANDOMIZED
}

// ─── Suite Invites ──────────────────────────────────────────────

model SuiteInvite {
  id          String        @id @default(cuid())
  suiteId     String
  suite       SuiteSession  @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  userId      String
  status      InviteStatus  @default(PENDING)
  sentAt      DateTime      @default(now())
  respondedAt DateTime?
  expiresAt   DateTime      // invite expires after N minutes
  joinedAt    DateTime?

  @@unique([suiteId, userId])
  @@index([suiteId])
  @@index([userId])
  @@index([status])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REMOVED
}

// ─── Webhook Event Log (idempotency for Stripe/Apple) ──────────

model WebhookEventLog {
  id         String   @id // provider event ID (e.g. evt_xxx for Stripe)
  provider   String   // "stripe" | "apple"
  eventType  String
  processedAt DateTime @default(now())

  @@index([provider])
  @@index([eventType])
}

// ─── Direct Messaging ───────────────────────────────────────────

model Conversation {
  id          String    @id @default(cuid())
  user1Id     String
  user1       User      @relation("ConvUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id     String
  user2       User      @relation("ConvUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  lastMessage String?
  lastAt      DateTime  @default(now())
  createdAt   DateTime  @default(now())

  messages DirectMessage[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastAt])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  content        String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}
