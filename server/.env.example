NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bewithme
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# Stripe (configure when ready)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Streaming
RTMP_SERVER_URL=rtmp://localhost:1935/live
# CDN_URL=https://cdn.bewithme.app

# AI Services (configure when ready)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# App URLs
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:3001

# Observability (Sentry — optional; errors are only reported when DSN is set)
# SENTRY_DSN=https://...@....ingest.sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.1
